{
  "name": "@run-iq/plugin-fiscal",
  "version": "0.2.2",
  "description": "Fiscal domain plugin for PPE — tax calculation models",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ && prettier --check src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix && prettier --write src/ tests/"
  },
  "peerDependencies": {
    "@run-iq/core": "^0.2.0",
    "@run-iq/plugin-sdk": "^0.2.2"
  },
  "dependencies": {
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@run-iq/dsl-jsonlogic": "^0.1.2",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Run-IQ/plugin-fiscal.git"
  },
  "homepage": "https://github.com/Run-IQ/plugin-fiscal#readme",
  "bugs": {
    "url": "https://github.com/Run-IQ/plugin-fiscal/issues"
  },
  "author": "Abdou-Raouf ATARMLA",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20.0.0"
  }
}
